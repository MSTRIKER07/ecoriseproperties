# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit your actual .env file to version control.

# Base URL for the future Backend API
# For local development, this might be http://localhost:5000/api
# For production, this will be your deployed backend URL
VITE_API_BASE_URL=https://api.yourdomain.com/v1

# Any other future public keys can go here
# VITE_GOOGLE_MAPS_API_KEY=your_key_here
